# ==================================================
# Eyes of Asclepius - Environment Configuration
# ==================================================

# ---- Application ----
APP_NAME=Eyes of Asclepius
APP_ENV=development
DEBUG=True

# ---- Database (PostgreSQL) ----
DB_HOST=localhost
DB_PORT=5432
DB_NAME=eyes_of_asclepius
DB_USER=postgres
DB_PASSWORD=postgres

# ---- Security Settings ----
# bcrypt hashing cost (higher = more secure, slower)
BCRYPT_ROUNDS=12

# RSA key size (2048 is secure and fast for academic use)
RSA_KEY_SIZE=2048

# AES key size in bytes (32 bytes = 256-bit AES)
AES_KEY_SIZE=32

# ---- Access Control ----
# Default referral access duration (in hours)
DEFAULT_REFERRAL_EXPIRY_HOURS=24

# ---- Timezone ----
TIMEZONE=Asia/Kolkata
